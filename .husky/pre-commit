#!/bin/sh

# ── Branch name check ─────────────────────────────────────────────────────────
# For students, name your branch after yourself:
#   feature/<your_name>           e.g. feature/nguyen_van_a
#   feature/<your_name>_<number>  e.g. feature/nguyen_van_a_1 (if name is taken)
#
# Other allowed patterns:
#   main | develop
#   fix/<description>
#   hotfix/<description>
#   release/<version>
#   chore/<description>

BRANCH=$(git symbolic-ref --short HEAD)
PATTERN="^(main|develop|feature/.+|fix/.+|hotfix/.+|release/.+|chore/.+)$"

if ! echo "$BRANCH" | grep -qE "$PATTERN"; then
  echo ""
  echo "✖ Invalid branch name: \"$BRANCH\""
  echo ""
  echo "  For students, use your name as the branch:"
  echo "    feature/nguyen_van_a"
  echo "    feature/nguyen_van_a_1   (if your name is already taken)"
  echo ""
  echo "  Other allowed patterns:"
  echo "    fix/<description>"
  echo "    hotfix/<description>"
  echo "    release/<version>"
  echo "    chore/<description>"
  echo ""
  exit 1
fi

# ── Lint & format staged files ─────────────────────────────────────────────────
npx lint-staged
