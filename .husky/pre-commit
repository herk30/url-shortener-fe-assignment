#!/bin/sh

# ── Branch name check ─────────────────────────────────────────────────────────
# Allowed patterns:
#   main | develop
#   feature/<description>
#   fix/<description>
#   hotfix/<description>
#   release/<version>
#   chore/<description>

BRANCH=$(git symbolic-ref --short HEAD)
PATTERN="^(main|develop|feature/.+|fix/.+|hotfix/.+|release/.+|chore/.+)$"

if ! echo "$BRANCH" | grep -qE "$PATTERN"; then
  echo ""
  echo "✖ Invalid branch name: \"$BRANCH\""
  echo ""
  echo "  Branch names must follow the convention:"
  echo "    main"
  echo "    develop"
  echo "    feature/<description>"
  echo "    fix/<description>"
  echo "    hotfix/<description>"
  echo "    release/<version>"
  echo "    chore/<description>"
  echo ""
  echo "  Example: feature/add-login-page"
  echo ""
  exit 1
fi

# ── Lint & format staged files ─────────────────────────────────────────────────
npx lint-staged
